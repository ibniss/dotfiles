{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "ghostty-workspaces",
  "title": "Ghostty Workspaces",
  "description": "Find, focus, and create project workspaces in Ghostty",
  "icon": "ghostty.png",
  "author": "kbiel",
  "platforms": [
    "macOS"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "switch-workspace",
      "title": "Switch Ghostty Workspace",
      "description": "Find an open Ghostty window or create a project workspace",
      "mode": "view"
    }
  ],
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  },
  "dependencies": {
    "@raycast/api": "^1.104.23",
    "@raycast/utils": "^2.2.7"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.4.13",
      "onFail": "warn"
    }
  }
}
